FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04
ARG DEBIAN_FRONTEND=noninteractive
SHELL ["/bin/bash", "-lc"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git bzip2 aria2 ffmpeg procps tini \
    build-essential libssl-dev \
  && rm -rf /var/lib/apt/lists/*

ENV MAMBA_ROOT_PREFIX=/opt/conda
ENV MAMBA_NO_BANNER=1
RUN curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/latest | \
    tar -xvj -C /usr/local/bin --strip-components=1 bin/micromamba

ENV CONDA_ENV=germinal
RUN micromamba create -y -n ${CONDA_ENV} python=3.10 && micromamba clean -a -y
ENV PATH=/opt/conda/envs/${CONDA_ENV}/bin:${PATH}
ENV PYTHONUNBUFFERED=1 MPLBACKEND=Agg HYDRA_FULL_ERROR=1 PIP_NO_CACHE_DIR=1

WORKDIR /workspace
COPY setup.py README.md ./
COPY colabdesign /workspace/colabdesign

RUN micromamba install -y -n ${CONDA_ENV} -c conda-forge openmm pdbfixer \
  && micromamba clean -a -y

RUN python -m pip install --upgrade pip wheel setuptools && python -m pip install uv

RUN uv pip install --system \
    pandas matplotlib numpy biopython scipy seaborn tqdm ffmpeg py3dmol \
    chex dm-haiku==0.0.13 dm-tree joblib ml-collections immutabledict \
    optax cvxopt mdtraj colabfold ipsae==1.0.1 freesasa MDAnalysis

RUN uv pip install --system \
    --index-url https://download.pytorch.org/whl/cu124 \
    "torch==2.6.0" "torchvision==0.21.0" "torchaudio==2.6.0"

RUN uv pip install --system torchtyping==0.1.5

RUN PYG_URL="https://data.pyg.org/whl/torch-2.6.0%2Bcu124.html" && \
    uv pip install --system "torch_geometric==2.6.*" -f "${PYG_URL}"

RUN uv pip install --system ablang && \
    uv pip install --system ablang2==0.2.1 --no-deps && \
    uv pip install --system rotary_embedding_torch==0.8.9 --no-deps && \
    uv pip install --system iglm chai-lab==0.6.1

RUN uv pip install --system jax==0.5.3 && \
    uv pip install --system hydra-core omegaconf && \
    uv pip install --system "jax[cuda12_pip]==0.5.3" \
    -f https://storage.googleapis.com/jax-releases/jax_cuda_releases.html

COPY . /workspace
RUN uv pip install --system -e /workspace/colabdesign && \
    uv pip install --system -e .

RUN mkdir -p /workspace/params /workspace/pdbs /workspace/results

CMD ["bash"]
